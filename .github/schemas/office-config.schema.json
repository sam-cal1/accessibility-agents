{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Office Accessibility Scan Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["docx", "xlsx", "pptx"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "docx": { "$ref": "#/definitions/officeFormat" },
    "xlsx": { "$ref": "#/definitions/officeFormat" },
    "pptx": { "$ref": "#/definitions/officeFormat" }
  },
  "definitions": {
    "officeFormat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "disabledRules", "severityFilter"],
      "properties": {
        "enabled": { "type": "boolean" },
        "disabledRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severityFilter": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["error", "warning", "tip"]
          },
          "minItems": 1
        }
      }
    }
  }
}